DATABASE_URL=

# Seguridad JWT
# SECRET_KEY debe ser una cadena larga y aleatoria - generarla así:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pegar_aqui_la_clave_generada
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_DAYS=7

# Claude API (Anthropic) - Sharon obtiene esta key de console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...

# reCAPTCHA - Barner obtiene estas keys de google.com/recaptcha
RECAPTCHA_SECRET_KEY=6Lc...

# Correo para recuperación de contraseña (usar SendGrid)
SENDGRID_API_KEY=SG....
EMAIL_FROM=pisst.sena@gmail.com

#------------------------------
# CORS (comma-separated). Example: http://localhost:3000,http://127.0.0.1:3000
APP_CORS_ORIGINS=

# Rate limiting (basic in-memory)
APP_LOGIN_LIMIT=5
APP_LOGIN_WINDOW_SECONDS=60
APP_REFRESH_LIMIT=10
APP_REFRESH_WINDOW_SECONDS=60