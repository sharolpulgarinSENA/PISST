# Base de datos (Neon, Supabase, PostgreSQL local, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Seguridad JWT — generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Gemini AI
GEMINI_API_KEY=

# Servicio de correo (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@tudominio.com

# Frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Entorno: development | production
ENVIRONMENT=development

# Endpoints administrativos internos
ADMIN_SECRET_KEY=cambia-esto-por-otra-clave-secreta

# Google reCAPTCHA
RECAPTCHA_SECRET_KEY=
